<idea-plugin>
    <id>io.github.batchref.idea</id>
    <name>BatchRef IDEA Support</name>
    <vendor email="support@example.com">BatchRef</vendor>

    <description><![CDATA[
        Adds completion, navigation, and rename support for @BatchQueryMethod method-name strings.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <psi.referenceContributor language="JAVA" implementation="io.github.batchref.idea.BatchQueryMethodReferenceContributor"/>
    </extensions>
</idea-plugin>
